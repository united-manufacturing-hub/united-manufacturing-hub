//go:build test
// +build test

package protocolconverter_test

import (
	"context"
	"fmt"
	"time"

	. "github.com/onsi/ginkgo/v2"
	. "github.com/onsi/gomega"

	"github.com/united-manufacturing-hub/united-manufacturing-hub/umh-core/internal/fsmtest"
	"github.com/united-manufacturing-hub/united-manufacturing-hub/umh-core/pkg/config"
	"github.com/united-manufacturing-hub/united-manufacturing-hub/umh-core/pkg/fsm"
	protocolconverterfsm "github.com/united-manufacturing-hub/united-manufacturing-hub/umh-core/pkg/fsm/protocolconverter"
	protocolconvertersvc "github.com/united-manufacturing-hub/united-manufacturing-hub/umh-core/pkg/service/protocolconverter"
	"github.com/united-manufacturing-hub/united-manufacturing-hub/umh-core/pkg/serviceregistry"
)

// Following the CursorRules, we never call manager.Reconcile(...) directly in loops.
// Instead, we use the fsmtest helpers.

var _ = Describe("ProtocolConverterManager", func() {
	var (
		manager         *protocolconverterfsm.ProtocolConverterManager
		mockService     *protocolconvertersvc.MockProtocolConverterService
		ctx             context.Context
		tick            uint64
		cancel          context.CancelFunc
		mockSvcRegistry *serviceregistry.Registry
	)

	AfterEach(func() {
		cancel()
	})

	BeforeEach(func() {
		ctx, cancel = context.WithTimeout(context.Background(), 10*time.Minute) // we need to have a deadline as the reconcile logic in the base fsm manager requires it
		tick = 0
		mockSvcRegistry = serviceregistry.NewMockRegistry()
		// Create a new ProtocolConverterManager with the mock service
		manager, mockService = fsmtest.CreateMockProtocolConverterManager("test-manager")

		// Initialize the mock service state to empty
		mockService.ExistingConverters = make(map[string]bool)
		mockService.ConverterStates = make(map[string]*protocolconvertersvc.ServiceInfo)
	})

	Context("Initialization", func() {
		It("should handle empty config without errors", func() {
			emptyConfig := config.FullConfig{ProtocolConverter: []config.ProtocolConverterConfig{}}

			// Single call to a helper that wraps Reconcile
			newTick, err := fsmtest.WaitForProtocolConverterManagerStable(
				ctx, fsm.SystemSnapshot{CurrentConfig: emptyConfig, Tick: tick}, manager, mockSvcRegistry,
			)
			tick = newTick
			Expect(err).NotTo(HaveOccurred())
			Expect(manager.GetInstances()).To(BeEmpty())
		})

		It("should create a converter in ready state and remain stable", func() {
			converterName := "test-ready-converter"
			cfg := config.FullConfig{
				ProtocolConverter: []config.ProtocolConverterConfig{
					fsmtest.CreateProtocolConverterTestConfig(converterName, protocolconverterfsm.OperationalStateReady),
				},
			}

			// Configure the mock service to allow transition to Ready
			fsmtest.ConfigureProtocolConverterManagerForState(mockService, converterName, protocolconverterfsm.OperationalStateReady)

			// Wait for instance creation and stable 'Ready' state
			newTick, err := fsmtest.WaitForProtocolConverterManagerInstanceState(
				ctx,
				fsm.SystemSnapshot{CurrentConfig: cfg, Tick: tick},
				manager,
				mockSvcRegistry,
				converterName,
				protocolconverterfsm.OperationalStateReady,
				10,
			)
			tick = newTick
			Expect(err).NotTo(HaveOccurred())

			// Double-check the manager state
			inst, exists := manager.GetInstance(fmt.Sprintf("protconv-%s", converterName))
			Expect(exists).To(BeTrue())
			Expect(inst.GetCurrentFSMState()).To(Equal(protocolconverterfsm.OperationalStateReady))
		})

		It("should create a converter in active state", func() {
			converterName := "test-active-converter"
			cfg := config.FullConfig{
				ProtocolConverter: []config.ProtocolConverterConfig{
					fsmtest.CreateProtocolConverterTestConfig(converterName, protocolconverterfsm.OperationalStateActive),
				},
			}

			// Configure the mock service for transition to Active
			fsmtest.ConfigureProtocolConverterManagerForState(mockService, converterName, protocolconverterfsm.OperationalStateActive)

			newTick, err := fsmtest.WaitForProtocolConverterManagerInstanceState(
				ctx,
				fsm.SystemSnapshot{CurrentConfig: cfg, Tick: tick},
				manager,
				mockSvcRegistry,
				converterName,
				protocolconverterfsm.OperationalStateActive,
				20,
			)
			tick = newTick
			Expect(err).NotTo(HaveOccurred())
		})
	})

	Context("Converter Lifecycle", func() {
		It("should go from creation -> active -> degrade -> removal", func() {
			converterName := "test-lifecycle"

			fullCfg := config.FullConfig{
				ProtocolConverter: []config.ProtocolConverterConfig{
					fsmtest.CreateProtocolConverterTestConfig(converterName, protocolconverterfsm.OperationalStateActive),
				},
			}

			fsmtest.ConfigureProtocolConverterManagerForState(mockService, converterName, protocolconverterfsm.OperationalStateActive)

			// 1) Wait for active
			newTick, err := fsmtest.WaitForProtocolConverterManagerInstanceState(ctx, fsm.SystemSnapshot{
				CurrentConfig: fullCfg,
				Tick:          tick,
			}, manager, mockSvcRegistry, converterName, protocolconverterfsm.OperationalStateActive, 20)
			tick = newTick
			Expect(err).NotTo(HaveOccurred())

			// 2) Now configure for degraded state
			fsmtest.ConfigureProtocolConverterManagerForState(mockService, converterName, protocolconverterfsm.OperationalStateDegraded)

			// Wait for state transition
			newTick, err = fsmtest.WaitForProtocolConverterManagerInstanceState(ctx, fsm.SystemSnapshot{
				CurrentConfig: fullCfg,
				Tick:          tick,
			}, manager, mockSvcRegistry, converterName, protocolconverterfsm.OperationalStateDegraded, 20)
			tick = newTick
			Expect(err).NotTo(HaveOccurred())
			Expect(manager.GetInstances()).To(HaveLen(1))

			// 3) Configure for ready state before removal
			fsmtest.ConfigureProtocolConverterManagerForState(mockService, converterName, protocolconverterfsm.OperationalStateReady)
			// Service is ready/idle at this point

			// Wait for removal
			emptyCfg := config.FullConfig{ProtocolConverter: []config.ProtocolConverterConfig{}}
			newTick, err = fsmtest.WaitForProtocolConverterManagerInstanceRemoval(
				ctx,
				fsm.SystemSnapshot{CurrentConfig: emptyCfg, Tick: tick},
				manager,
				mockSvcRegistry,
				fmt.Sprintf("protconv-%s", converterName),
				20,
			)
			tick = newTick
			Expect(err).NotTo(HaveOccurred())
			Expect(manager.GetInstances()).NotTo(HaveKey(fmt.Sprintf("protconv-%s", converterName)))
		})

		It("should toggle from active to ready and back to active with config changes", func() {
			converterName := "test-toggle-converter"
			activeCfg := fsmtest.CreateProtocolConverterTestConfig(converterName, protocolconverterfsm.OperationalStateActive)
			readyCfg := fsmtest.CreateProtocolConverterTestConfig(converterName, protocolconverterfsm.OperationalStateReady)

			// Start with Active
			fullCfg := config.FullConfig{
				ProtocolConverter: []config.ProtocolConverterConfig{activeCfg},
			}

			// Configure for active state
			fsmtest.ConfigureProtocolConverterManagerForState(mockService, converterName, protocolconverterfsm.OperationalStateActive)

			// Wait for active
			newTick, err := fsmtest.WaitForProtocolConverterManagerInstanceState(
				ctx,
				fsm.SystemSnapshot{CurrentConfig: fullCfg, Tick: tick},
				manager,
				mockSvcRegistry,
				converterName,
				protocolconverterfsm.OperationalStateActive,
				15,
			)
			tick = newTick
			Expect(err).NotTo(HaveOccurred())

			// Now switch to Ready
			readyCfgFull := config.FullConfig{
				ProtocolConverter: []config.ProtocolConverterConfig{readyCfg},
			}

			// Configure for ready state
			fsmtest.ConfigureProtocolConverterManagerForState(mockService, converterName, protocolconverterfsm.OperationalStateReady)

			// Wait for ready
			newTick, err = fsmtest.WaitForProtocolConverterManagerInstanceState(
				ctx,
				fsm.SystemSnapshot{CurrentConfig: readyCfgFull, Tick: tick},
				manager,
				mockSvcRegistry,
				converterName,
				protocolconverterfsm.OperationalStateReady,
				15,
			)
			tick = newTick
			Expect(err).NotTo(HaveOccurred())

			// Finally, switch back to Active
			// Configure for active state
			fsmtest.ConfigureProtocolConverterManagerForState(mockService, converterName, protocolconverterfsm.OperationalStateActive)

			// Wait for active again
			newTick, err = fsmtest.WaitForProtocolConverterManagerInstanceState(
				ctx,
				fsm.SystemSnapshot{CurrentConfig: fullCfg, Tick: tick},
				manager,
				mockSvcRegistry,
				converterName,
				protocolconverterfsm.OperationalStateActive,
				15,
			)
			tick = newTick
			Expect(err).NotTo(HaveOccurred())
		})
	})
})
